datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  clerkId        String         @unique
  credits        Int            @default(10)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  subscription   Subscription?
  creditsLogs    CreditsLog[]
  videos         Video[]
  series         Series[]
  channels       Channel[]
  templates      Template[]
  marketplaceBuy MarketplaceListing[] @relation("BuyerRelation")
  voiceClones    VoiceClone[]
}

model Subscription {
  id                     String           @id @default(uuid())
  userId                 String           @unique
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   String           @default("FREE") // "FREE", "STARTER", "CREATOR", "PRO", "AGENCE"
  status                 String           // "active", "canceled", "incomplete"
  stripeSubscriptionId   String?          @unique
  stripeCustomerId       String?
  currentPeriodEnd       DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model CreditsLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditsChanged Int      
  reason         String   // "VIDEO_GENERATION", "PACK_PURCHASE", "REFUND"
  createdAt      DateTime @default(now())
}

model Video {
  id             String               @id @default(uuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  script         String               
  niche          String
  style          String               
  tone           String               
  duration       Int                  
  language       String               
  
  status         String               @default("PENDING") // PENDING, SCRIPT_DONE, VOICE_DONE, IMAGES_DONE, CAPTIONS_DONE, RENDERING, COMPLETED, FAILED
  videoUrl       String?              
  voiceUrl       String?              
  subtitles      String?              // Stored as JSON string in SQLite
  musicUrl       String?              
  
  viralScore     Int?                 
  suggestions    String?              // Stored as JSON string in SQLite
  
  seriesId       String?
  series         Series?              @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  
  jobs           VideoJob[]
  analytics      AnalyticsSnapshot[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model VideoJob {
  id          String      @id @default(uuid())
  videoId     String
  video       Video       @relation(fields: [videoId], references: [id], onDelete: Cascade)
  jobType     String      @default("SINGLE_VIDEO") // SINGLE_VIDEO, SERIES_VIDEO
  progress    Int         @default(0) 
  status      String      @default("PENDING")
  error       String?     
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Series {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  niche         String
  videoCount    Int
  intervalHours Int       @default(24)
  status        String    @default("ACTIVE") // "ACTIVE", "COMPLETED", "PAUSED"
  videos        Video[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Channel {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String    // TIKTOK, INSTAGRAM, YOUTUBE, PINTEREST, SNAPCHAT, X
  accountName    String
  accessToken    String    
  refreshToken   String?   
  tokenExpiresAt DateTime?
  watermarkUrl   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Template {
  id             String               @id @default(uuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  previewUrl     String?
  remotionConfig String               // Stored as JSON string in SQLite
  priceCredits   Int                  @default(0) 
  isPublic       Boolean              @default(false)
  rating         Float                @default(5.0)
  listings       MarketplaceListing[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model MarketplaceListing {
  id          String   @id @default(uuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sellerId    String
  buyerId     String?
  buyer       User?    @relation("BuyerRelation", fields: [buyerId], references: [id], onDelete: SetNull)
  priceCredits Int
  status      String   @default("AVAILABLE") // "AVAILABLE", "SOLD"
  createdAt   DateTime @default(now())
}

model AnalyticsSnapshot {
  id          String   @id @default(uuid())
  videoId     String
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  views       Int      @default(0)
  likes       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)
  recordedAt  DateTime @default(now())
}

model VoiceClone {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceId   String      @unique 
  name      String
  sampleUrl String
  status    String      @default("PROCESSING") // PROCESSING, READY, FAILED
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
